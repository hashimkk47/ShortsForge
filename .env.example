# ===========================================================================
# ShortsForge configuration. Copy to `.env` and fill in what you need.
# Every value is optional and falls back to a sensible default.
# ===========================================================================

# --- API mode (--mode api) ------------------------------------------------
# One key powers download, transcription, highlight ranking, and autocrop.
MUAPI_API_KEY=your_muapi_key_here

# --- Local mode (--mode local): highlight LLM -----------------------------
# Pick a provider: ollama (fully offline), openai, or gemini.
LLM_PROVIDER=ollama

# Ollama (offline, recommended for local mode) — needs a running Ollama server.
OLLAMA_MODEL=qwen3:8b
OLLAMA_HOST=http://localhost:11434

# OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini (LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Local mode: Whisper transcription ------------------------------------
# tiny / base / small / medium / large-v3. large-v3 is most accurate but needs
# a capable GPU; base is a good CPU default.
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=auto          # auto / cpu / cuda

# --- Local mode: face tracking (advanced) ---------------------------------
# LOCAL_FACE_MIN_CONFIDENCE=0.5
# LOCAL_FACE_MODEL_PATH=            # use a local .tflite instead of downloading
# LOCAL_SUBTITLE_STYLE=            # override the burned-in subtitle ASS style

# --- Output ---------------------------------------------------------------
LOCAL_OUTPUT_DIR=output
